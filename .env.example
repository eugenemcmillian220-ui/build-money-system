# ============================================================
# AI App Builder - Environment Variables
# ============================================================
# Copy this file to .env.local and fill in your values.
# OpenCode Zen API keys support comma-separated multi-key rotation.
# ============================================================

# ── Supabase ─────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_ACCESS_TOKEN=sbp_...
SUPABASE_MANAGEMENT_API_KEY=sbp_...

# ── Arize AI (OTel) ──────────────────────────────────────────
ARIZE_API_KEY=ak-...
ARIZE_SPACE_ID=...
OTEL_EXPORTER_OTLP_ENDPOINT=https://otlp.arize.com/v1
OTEL_EXPORTER_OTLP_HEADERS=space_id=...,Authorization=ak-...

# ── Analytics & Monitoring ───────────────────────────────────
NEXT_PUBLIC_SENTRY_DSN=https://...
NEXT_PUBLIC_POSTHOG_KEY=phc_...
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# ── Site URL ─────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://your-app.vercel.app

# ── AI Providers (Smart Multi-Provider Rotation) ──────────────
# The system auto-rotates across all configured providers for high
# availability and speed. At least one provider must be configured.
#
# --- OpenCode Zen ---
OPENCODE_ZEN_API_KEY=sk-zen-v1-your-key-here
OPENCODE_ZEN_API_KEYS=sk-zen-v1-key1,sk-zen-v1-key2
OPENCODE_ZEN_API_URL=https://opencode.ai/zen/go/v1/chat/completions
OPENCODE_ZEN_EMBED_URL=https://opencode.ai/zen/go/v1/embeddings
# Free: deepseek-v4-flash, glm-5, mimo-v2.5, qwen3.5-plus, kimi-k2.5, minimax-m2.5
# Paid: kimi-k2.6, glm-5.1, mimo-v2-pro, mimo-v2-omni, mimo-v2.5-pro, minimax-m2.7, qwen3.6-plus, deepseek-v4-pro
#
# --- GitHub Models (free tier) ---
# Uses your GitHub PAT with models:read scope
# Endpoint: https://models.github.ai/inference/chat/completions
# Free: openai/gpt-4.1-mini, openai/gpt-4.1-nano, meta-llama/Llama-4-Scout-17B-16E-Instruct,
#   meta-llama/Meta-Llama-3.1-8B-Instruct, mistralai/Mistral-Small-24B-Instruct-2501,
#   deepseek/DeepSeek-V3-0324, microsoft/Phi-4, Cohere/cohere-command-a
GITHUB_MODELS_API_URL=https://models.github.ai/inference/chat/completions
#
# --- Hugging Face Inference (free tier) ---
# Uses your HF token: https://huggingface.co/settings/tokens
# Endpoint: https://router.huggingface.co/v1/chat/completions
# Free: deepseek-ai/DeepSeek-V3-0324, meta-llama/Llama-3.1-8B-Instruct,
#   Qwen/Qwen2.5-72B-Instruct, mistralai/Mistral-Small-24B-Instruct-2501,
#   microsoft/Phi-3.5-mini-instruct, google/gemma-2-2b-it
HF_TOKEN=hf_your_token_here
HF_API_URL=https://router.huggingface.co/v1/chat/completions
#

# ── Stripe ───────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_ACCOUNT_ID=acct_...

# === SUBSCRIPTION TIERS ===
# Basic Tiers
STRIPE_BASIC_MINI_MONTHLY_PRICE_ID=price_basic_mini_monthly_placeholder
STRIPE_BASIC_MINI_YEARLY_PRICE_ID=price_basic_mini_yearly_placeholder
STRIPE_BASIC_STARTER_MONTHLY_PRICE_ID=price_basic_starter_monthly_placeholder
STRIPE_BASIC_STARTER_YEARLY_PRICE_ID=price_basic_starter_yearly_placeholder
STRIPE_BASIC_PRO_MONTHLY_PRICE_ID=price_basic_pro_monthly_placeholder
STRIPE_BASIC_PRO_YEARLY_PRICE_ID=price_basic_pro_yearly_placeholder
STRIPE_BASIC_PREMIUM_MONTHLY_PRICE_ID=price_basic_premium_monthly_placeholder
STRIPE_BASIC_PREMIUM_YEARLY_PRICE_ID=price_basic_premium_yearly_placeholder

# Elite Tiers
STRIPE_ELITE_STARTER_MONTHLY_PRICE_ID=price_elite_starter_monthly_placeholder
STRIPE_ELITE_STARTER_YEARLY_PRICE_ID=price_elite_starter_yearly_placeholder
STRIPE_ELITE_PRO_MONTHLY_PRICE_ID=price_elite_pro_monthly_placeholder
STRIPE_ELITE_PRO_YEARLY_PRICE_ID=price_elite_pro_yearly_placeholder
STRIPE_ELITE_ENTERPRISE_MONTHLY_PRICE_ID=price_elite_enterprise_monthly_placeholder
STRIPE_ELITE_ENTERPRISE_YEARLY_PRICE_ID=price_elite_enterprise_yearly_placeholder

# Lifetime Licenses
STRIPE_LIFETIME_STARTER_PRICE_ID=price_lifetime_starter_placeholder
STRIPE_LIFETIME_PRO_PRICE_ID=price_lifetime_pro_placeholder
STRIPE_ON_PREM_PERPETUAL_PRICE_ID=price_onprem_perpetual_placeholder

# Credit Top-Up Packs
STRIPE_CREDITS_5K_PRICE_ID=price_credits_5k_placeholder
STRIPE_CREDITS_10K_PRICE_ID=price_credits_10k_placeholder
STRIPE_CREDITS_25K_PRICE_ID=price_credits_25k_placeholder
STRIPE_CREDITS_50K_PRICE_ID=price_credits_50k_placeholder
STRIPE_CREDITS_100K_PRICE_ID=price_credits_100k_placeholder

# ── Deployment ───────────────────────────────────────────────
# GitHub - token with 'repo' scope: https://github.com/settings/tokens
GITHUB_ACCESS_TOKEN=ghp_your_token_here
GITHUB_USERNAME=your_username
GITHUB_REPO=your_username/your_repo
GITHUB_DEFAULT_BRANCH=main
GITHUB_TOKEN=ghp_your_token_here

# Vercel - token from: https://vercel.com/account/tokens
VERCEL_ACCESS_TOKEN=your_vercel_token_here
VERCEL_PROJECT_ID=your_project_id
VERCEL_TEAM_ID=your_team_id
VERCEL_TOKEN=your_vercel_token_here

# ── Admin ────────────────────────────────────────────────────
# Comma-separated admin API keys for protected endpoints
ADMIN_API_KEYS=sk-admin-key-1,sk-admin-key-2

# ── Sandbox ──────────────────────────────────────────────────
# E2B - get API key from https://e2b.dev
E2B_API_KEY=e2b_your_api_key_here

# Cron secret for autonomous task scheduling
CRON_SECRET=your_random_secret_here

# ── Social Integrations ───────────────────────────────────────
DISCORD_TOKEN=your_discord_token
SLACK_TOKEN=your_slack_token
SLACK_BOT_TOKEN=your_slack_bot_token
SLACK_WEBHOOK_URL=your_slack_webhook_url
SLACK_CHANNEL_ID=your_slack_channel_id

# ── Worker Secret ─────────────────────────────────────────────────────────────
# Required for inter-stage manifest pipeline authentication.
# Generate with: openssl rand -hex 32
WORKER_SHARED_SECRET=your-random-32-char-secret-here
