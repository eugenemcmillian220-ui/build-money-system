# Supabase - get these from your Supabase project settings
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# OpenRouter - get your API key from https://openrouter.ai
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# Optional: set your site URL for OpenRouter attribution
NEXT_PUBLIC_SITE_URL=https://your-app.vercel.app

# Optional: Stripe integration (for checkout API routes)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Price IDs (populate these after running scripts/setup-stripe.ts)
# Basic Tiers
STRIPE_PRICE_BASIC_MINI_MONTHLY=price_...
STRIPE_PRICE_BASIC_MINI_YEARLY=price_...
STRIPE_PRICE_BASIC_STARTER_MONTHLY=price_...
STRIPE_PRICE_BASIC_STARTER_YEARLY=price_...
STRIPE_PRICE_BASIC_PRO_MONTHLY=price_...
STRIPE_PRICE_BASIC_PRO_YEARLY=price_...
STRIPE_PRICE_BASIC_PREMIUM_MONTHLY=price_...
STRIPE_PRICE_BASIC_PREMIUM_YEARLY=price_...

# Elite Tiers
STRIPE_PRICE_ELITE_STARTER_MONTHLY=price_...
STRIPE_PRICE_ELITE_STARTER_YEARLY=price_...
STRIPE_PRICE_ELITE_PRO_MONTHLY=price_...
STRIPE_PRICE_ELITE_PRO_YEARLY=price_...
STRIPE_PRICE_ELITE_ENTERPRISE_MONTHLY=price_...
STRIPE_PRICE_ELITE_ENTERPRISE_YEARLY=price_...

# Phase 4: GitHub Export - create a token with 'repo' scope at https://github.com/settings/tokens
GITHUB_TOKEN=ghp_your_token_here

# Phase 4: Vercel Deployment - create a token at https://vercel.com/account/tokens
VERCEL_TOKEN=your_vercel_token_here

# Phase 4: Vercel Team ID (optional - only needed for team deployments)
# VERCEL_TEAM_ID=your_team_id

# Phase 5: Admin API Keys (comma-separated, for protected endpoints like self-improvement)
ADMIN_API_KEYS=sk-admin-key-1,sk-admin-key-2

