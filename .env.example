# Supabase - get these from your Supabase project settings
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# OpenRouter - get your API key from https://openrouter.ai
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# Optional: set your site URL for OpenRouter attribution
NEXT_PUBLIC_SITE_URL=https://your-app.vercel.app

# Optional: Stripe integration (for checkout API routes)
STRIPE_SECRET_KEY=sk_test_...

# Phase 4: GitHub Export - create a token with 'repo' scope at https://github.com/settings/tokens
GITHUB_TOKEN=ghp_your_token_here

# Phase 4: Vercel Deployment - create a token at https://vercel.com/account/tokens
VERCEL_TOKEN=your_vercel_token_here

# Phase 4: Vercel Team ID (optional - only needed for team deployments)
# VERCEL_TEAM_ID=your_team_id

