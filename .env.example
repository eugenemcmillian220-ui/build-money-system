# ============================================================
# AI App Builder - Environment Variables
# ============================================================
# Copy this file to .env.local and fill in your values.
# All AI provider keys support comma-separated multi-key rotation.
# ============================================================

# ── Supabase ─────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_ACCESS_TOKEN=sbp_...

# ── Arize AI (OTel) ──────────────────────────────────────────
ARIZE_API_KEY=ak-...
ARIZE_SPACE_ID=...
OTEL_EXPORTER_OTLP_ENDPOINT=https://otlp.arize.com/v1
OTEL_EXPORTER_OTLP_HEADERS=space_id=...,Authorization=ak-...

# ── Analytics & Monitoring ───────────────────────────────────
NEXT_PUBLIC_SENTRY_DSN=https://...
NEXT_PUBLIC_POSTHOG_KEY=phc_...
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# ── Site URL ─────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://your-app.vercel.app

# ── OpenRouter ───────────────────────────────────────────────
# Single key or comma-separated list for rotation:
# OPENROUTER_API_KEYS=sk-or-v1-key1,sk-or-v1-key2,sk-or-v1-key3
OPENROUTER_API_KEY=sk-or-v1-your-key-here
# OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free

# ── Groq (fastest inference) ─────────────────────────────────
# Supports multi-key rotation:
# GROQ_API_KEYS=gsk_key1,gsk_key2,gsk_key3
GROQ_API_KEY=gsk_your-key-here

# ── Google Gemini ─────────────────────────────────────────────
# Supports multi-key rotation:
# GEMINI_API_KEYS=AIza-key1,AIza-key2,AIza-key3
GEMINI_API_KEY=AIza-your-key-here

# ── OpenAI ───────────────────────────────────────────────────
# Supports multi-key rotation:
# OPENAI_API_KEYS=sk-proj-key1,sk-proj-key2
OPENAI_API_KEY=sk-proj-your-key-here

# ── DeepSeek ─────────────────────────────────────────────────
DEEPSEEK_API_KEY=your-deepseek-key-here

# ── Cerebras ─────────────────────────────────────────────────
CEREBRAS_API_KEY=your-cerebras-key-here

# ── Cloudflare Workers AI ─────────────────────────────────────
CLOUDFLARE_API_KEY=your-cloudflare-key-here
CLOUDFLARE_ACCOUNT_ID=your-account-id-here

# ── Stripe ───────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# === SUBSCRIPTION TIERS ===
# Basic Tiers
STRIPE_BASIC_MINI_MONTHLY_PRICE_ID=price_basic_mini_monthly_placeholder
STRIPE_BASIC_MINI_YEARLY_PRICE_ID=price_basic_mini_yearly_placeholder
STRIPE_BASIC_STARTER_MONTHLY_PRICE_ID=price_basic_starter_monthly_placeholder
STRIPE_BASIC_STARTER_YEARLY_PRICE_ID=price_basic_starter_yearly_placeholder
STRIPE_BASIC_PRO_MONTHLY_PRICE_ID=price_basic_pro_monthly_placeholder
STRIPE_BASIC_PRO_YEARLY_PRICE_ID=price_basic_pro_yearly_placeholder
STRIPE_BASIC_PREMIUM_MONTHLY_PRICE_ID=price_basic_premium_monthly_placeholder
STRIPE_BASIC_PREMIUM_YEARLY_PRICE_ID=price_basic_premium_yearly_placeholder

# Elite Tiers
STRIPE_ELITE_STARTER_MONTHLY_PRICE_ID=price_elite_starter_monthly_placeholder
STRIPE_ELITE_STARTER_YEARLY_PRICE_ID=price_elite_starter_yearly_placeholder
STRIPE_ELITE_PRO_MONTHLY_PRICE_ID=price_elite_pro_monthly_placeholder
STRIPE_ELITE_PRO_YEARLY_PRICE_ID=price_elite_pro_yearly_placeholder
STRIPE_ELITE_ENTERPRISE_MONTHLY_PRICE_ID=price_elite_enterprise_monthly_placeholder
STRIPE_ELITE_ENTERPRISE_YEARLY_PRICE_ID=price_elite_enterprise_yearly_placeholder

# Lifetime Licenses
STRIPE_LIFETIME_STARTER_PRICE_ID=price_lifetime_starter_placeholder
STRIPE_LIFETIME_PRO_PRICE_ID=price_lifetime_pro_placeholder
STRIPE_ON_PREM_PERPETUAL_PRICE_ID=price_onprem_perpetual_placeholder

# Credit Top-Up Packs
STRIPE_CREDITS_5K_PRICE_ID=price_credits_5k_placeholder
STRIPE_CREDITS_10K_PRICE_ID=price_credits_10k_placeholder
STRIPE_CREDITS_25K_PRICE_ID=price_credits_25k_placeholder
STRIPE_CREDITS_50K_PRICE_ID=price_credits_50k_placeholder
STRIPE_CREDITS_100K_PRICE_ID=price_credits_100k_placeholder

# ── Deployment ───────────────────────────────────────────────
# GitHub - token with 'repo' scope: https://github.com/settings/tokens
GITHUB_TOKEN=ghp_your_token_here

# Vercel - token from: https://vercel.com/account/tokens
VERCEL_TOKEN=your_vercel_token_here
# VERCEL_TEAM_ID=your_team_id

# ── Admin ────────────────────────────────────────────────────
# Comma-separated admin API keys for protected endpoints
ADMIN_API_KEYS=sk-admin-key-1,sk-admin-key-2

# ── Sandbox ──────────────────────────────────────────────────
# E2B - get API key from https://e2b.dev
E2B_API_KEY=e2b_your_api_key_here

# Cron secret for autonomous task scheduling
CRON_SECRET=your_random_secret_here

# ── Social Integrations ───────────────────────────────────────
X_API_KEY=your_x_api_key
X_API_SECRET=your_x_api_secret
X_ACCESS_TOKEN=your_x_access_token
X_ACCESS_SECRET=your_x_access_secret
LINKEDIN_CLIENT_ID=your_linkedin_client_id
LINKEDIN_CLIENT_SECRET=your_linkedin_client_secret
DISCORD_TOKEN=your_discord_token
SLACK_TOKEN=your_slack_token
