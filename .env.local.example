# ============================================================
# AI App Builder - Multi-Key Rotation Configuration
# ============================================================
# This file demonstrates how to configure multiple API keys
# for automatic rotation and failover across all LLM providers.
# ============================================================
# Copy this file to .env.local and fill in your actual keys.
# ============================================================

# ── Supabase ─────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_ACCESS_TOKEN=sbp_...

# ── OpenRouter (Primary Provider) ─────────────────────────────
# Multi-key rotation - keys are rotated automatically
# Format: comma-separated or newline-separated list
OPENROUTER_API_KEYS=sk-or-v1-key1,sk-or-v1-key2,sk-or-v1-key3,sk-or-v1-key4,sk-or-v1-key5
# OR for single key:
# OPENROUTER_API_KEY=sk-or-v1-your-key-here
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free

# ── Groq (Fastest Inference) ─────────────────────────────────
# Multi-key rotation - perfect for high-volume requests
# Recommended: 3-5 keys for optimal rotation
GROQ_API_KEYS=gsk_key1,gsk_key2,gsk_key3,gsk_key4,gsk_key5
# OR for single key:
# GROQ_API_KEY=gsk_your-key-here

# ── Google Gemini ────────────────────────────────────────────
# Multi-key rotation - supports both comma and newline separation
GEMINI_API_KEYS=AIza-key1,AIza-key2,AIza-key3,AIza-key4
# OR for single key:
# GEMINI_API_KEY=AIza-your-key-here

# ── OpenAI ───────────────────────────────────────────────────
# Multi-key rotation - essential for rate limit management
# Recommended: 2-3 keys at minimum
OPENAI_API_KEYS=sk-proj-key1,sk-proj-key2,sk-proj-key3
# OR for single key:
# OPENAI_API_KEY=sk-proj-your-key-here

# ── DeepSeek ─────────────────────────────────────────────────
# Multi-key rotation (if you have multiple keys)
DEEPSEEK_API_KEYS=deepseek-key1,deepseek-key2,deepseek-key3
# OR for single key:
# DEEPSEEK_API_KEY=your-deepseek-key-here

# ── Cerebras ─────────────────────────────────────────────────
# Multi-key rotation
CEREBRAS_API_KEYS=cerebras-key1,cerebras-key2
# OR for single key:
# CEREBRAS_API_KEY=your-cerebras-key-here

# ── Cloudflare Workers AI ─────────────────────────────────────
# Multi-key rotation
CLOUDFLARE_API_KEYS=cf-key1,cf-key2,cf-key3
# OR for single key:
# CLOUDFLARE_API_KEY=your-cloudflare-api-key-here
CLOUDFLARE_ACCOUNT_ID=your-cloudflare-account-id-here

# ============================================================
# Multi-Key Rotation Features:
# ============================================================
#
# 1. AUTOMATIC ROTATION
#    - Keys are rotated using round-robin algorithm
#    - Evenly distributes load across all keys
#    - Prevents rate limiting on individual keys
#
# 2. ERROR TRACKING
#    - Tracks error count per key
#    - Automatically disables failing keys
#    - Applies 60-second cooldown after 3 errors
#
# 3. FAILOVER
#    - If a key fails, system rotates to next available key
#    - Automatically recovers failed keys after cooldown
#    - Ensures continuous service availability
#
# 4. PROVIDER PRIORITY
#    - Groq (fastest) → Gemini → OpenRouter → OpenAI → Cerebras → DeepSeek → Cloudflare
#    - System uses configured providers in priority order
#    - Skips providers without keys automatically
#
# 5. FLEXIBLE CONFIGURATION
#    - Supports comma-separated: key1,key2,key3
#    - Supports newline-separated: key1\nkey2\nkey3
#    - Supports mixed separators: key1,key2\nkey3
#    - Automatically trims whitespace
#    - Filters empty keys automatically
#
# ============================================================
# Usage Examples:
# ============================================================
#
# Example 1: Single key (legacy format)
#   GROQ_API_KEY=gsk_abc123xyz
#
# Example 2: Multiple keys (recommended)
#   GROQ_API_KEYS=gsk_key1,gsk_key2,gsk_key3,gsk_key4,gsk_key5
#
# Example 3: Multi-line for readability
#   OPENAI_API_KEYS=sk-proj-key1
#   sk-proj-key2
#   sk-proj-key3
#   sk-proj-key4
#
# Example 4: Mixed separators
#   GEMINI_API_KEYS=AIza-key1,AIza-key2
#   AIza-key3,AIza-key4
#
# ============================================================
# Best Practices:
# ============================================================
#
# 1. Use 3-5 keys per provider for optimal rotation
# 2. Get keys from different accounts/projects when possible
# 3. Monitor error rates and adjust key counts accordingly
# 4. Use API_KEYS (plural) for multi-key configuration
# 5. Keep API_KEY (singular) as fallback
# 6. Set up alerts for rate limit usage
# 7. Rotate keys periodically for security
#
# ============================================================

# ── Arize AI (OTel) ──────────────────────────────────────────
ARIZE_API_KEY=ak-...
ARIZE_SPACE_ID=...
OTEL_EXPORTER_OTLP_ENDPOINT=https://otlp.arize.com/v1
OTEL_EXPORTER_OTLP_HEADERS=space_id=...,Authorization=ak-...

# ── Analytics & Monitoring ───────────────────────────────────
NEXT_PUBLIC_SENTRY_DSN=https://...
NEXT_PUBLIC_POSTHOG_KEY=phc_...
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# ── Site URL ─────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://your-app.vercel.app

# ── Stripe ───────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# === SUBSCRIPTION TIERS ===
# Basic Tiers
STRIPE_BASIC_MINI_MONTHLY_PRICE_ID=price_basic_mini_monthly_placeholder
STRIPE_BASIC_MINI_YEARLY_PRICE_ID=price_basic_mini_yearly_placeholder
STRIPE_BASIC_STARTER_MONTHLY_PRICE_ID=price_basic_starter_monthly_placeholder
STRIPE_BASIC_STARTER_YEARLY_PRICE_ID=price_basic_starter_yearly_placeholder
STRIPE_BASIC_PRO_MONTHLY_PRICE_ID=price_basic_pro_monthly_placeholder
STRIPE_BASIC_PRO_YEARLY_PRICE_ID=price_basic_pro_yearly_placeholder
STRIPE_BASIC_PREMIUM_MONTHLY_PRICE_ID=price_basic_premium_monthly_placeholder
STRIPE_BASIC_PREMIUM_YEARLY_PRICE_ID=price_basic_premium_yearly_placeholder

# Elite Tiers
STRIPE_ELITE_STARTER_MONTHLY_PRICE_ID=price_elite_starter_monthly_placeholder
STRIPE_ELITE_STARTER_YEARLY_PRICE_ID=price_elite_starter_yearly_placeholder
STRIPE_ELITE_PRO_MONTHLY_PRICE_ID=price_elite_pro_monthly_placeholder
STRIPE_ELITE_PRO_YEARLY_PRICE_ID=price_elite_pro_yearly_placeholder
STRIPE_ELITE_ENTERPRISE_MONTHLY_PRICE_ID=price_elite_enterprise_monthly_placeholder
STRIPE_ELITE_ENTERPRISE_YEARLY_PRICE_ID=price_elite_enterprise_yearly_placeholder

# Lifetime Licenses
STRIPE_LIFETIME_STARTER_PRICE_ID=price_lifetime_starter_placeholder
STRIPE_LIFETIME_PRO_PRICE_ID=price_lifetime_pro_placeholder
STRIPE_ON_PREM_PERPETUAL_PRICE_ID=price_onprem_perpetual_placeholder

# Credit Top-Up Packs
STRIPE_CREDITS_5K_PRICE_ID=price_credits_5k_placeholder
STRIPE_CREDITS_10K_PRICE_ID=price_credits_10k_placeholder
STRIPE_CREDITS_25K_PRICE_ID=price_credits_25k_placeholder
STRIPE_CREDITS_50K_PRICE_ID=price_credits_50k_placeholder
STRIPE_CREDITS_100K_PRICE_ID=price_credits_100k_placeholder

# ── Deployment ───────────────────────────────────────────────
# GitHub - token with 'repo' scope: https://github.com/settings/tokens
GITHUB_TOKEN=ghp_your_token_here

# Vercel - token from: https://vercel.com/account/tokens
VERCEL_TOKEN=your_vercel_token_here
# VERCEL_TEAM_ID=your_team_id

# ── Admin ────────────────────────────────────────────────────
# Comma-separated admin API keys for protected endpoints
ADMIN_API_KEYS=sk-admin-key-1,sk-admin-key-2

# ── Sandbox ──────────────────────────────────────────────────
# E2B - get API key from https://e2b.dev
E2B_API_KEY=e2b_your_api_key_here

# Cron secret for autonomous task scheduling
CRON_SECRET=your_random_secret_here

# ── Social Integrations ───────────────────────────────────────
DISCORD_TOKEN=your_discord_token
SLACK_TOKEN=your_slack_token
