⚙️ 1. AGENT SWARM SYSTEM

lib/agent-swarm.ts

export type AgentTask = {
  role: string
  input: string
}

export async function runAgentSwarm(tasks: AgentTask[]) {
  const results = await Promise.all(
    tasks.map(async (task) => {
      return {
        role: task.role,
        output: `Processed by ${task.role}: ${task.input}`
      }
    })
  )

  return results
}


