🧠 1. COMPANY ORCHESTRATOR

lib/company-orchestrator.ts

import { runAITeam } from "./ai-team"
import { validateIdea } from "./idea-validator"
import { planProduct } from "./product-planner"
import { launchGrowth } from "./growth-engine"
import { startMonetization } from "./monetization"

export async function buildCompany(idea: string) {
  const validation = await validateIdea(idea)
  const plan = await planProduct(idea)

  const teamOutput = await runAITeam([
    { role: "pm", input: plan },
    { role: "engineer", input: plan },
    { role: "designer", input: plan }
  ])

  const growth = await launchGrowth(idea)
  const revenue = await startMonetization(idea)

  return {
    validation,
    plan,
    teamOutput,
    growth,
    revenue
  }
}


