// ============================= // 7. AGENT ORCHESTRATOR (lib/agent.ts) // ============================= import { v4 as uuidv4 } from "uuid"; import { generateAppSpec, debugFiles } from "./openrouter"; import { attachBackend } from "./backend"; import { applyIntegrations } from "./integrations"; import { saveProject } from "./memory"; import type { GeneratedApp } from "./types";

export async function buildAppAgent(prompt: string): Promise<{ id: string; app: GeneratedApp }> { // 1) Generate spec const raw = await generateAppSpec(prompt);

let parsed: GeneratedApp = { files: {} }; try { parsed = JSON.parse(raw); } catch { throw new Error("Invalid JSON from model"); }

// 2) Attach backend + schema let files = attachBackend(parsed.files || {}, parsed.schema);

// 3) Apply integrations files = applyIntegrations(files, parsed.integrations);

// 4) Debug pass files = await debugFiles(files);

// 5) Save project const id = uuidv4(); saveProject(id, files);

return { id, app: { ...parsed, files } }; }

// ============================= // 8. API ROUTES // ============================= // app/api/generate/route.ts import { NextRequest, NextResponse } from "next/server"; import { buildAppAgent } from "@/lib/agent";

export async function POST(req: NextRequest) { try { const { prompt } = await req.json(); if (!prompt) return NextResponse.json({ error: "Prompt required" }, { status: 400 });

const result = await buildAppAgent(prompt);
return NextResponse.json(result);

} catch (e: any) { return NextResponse.json({ error: e.message || "Generation failed" }, { status: 500 }); } }

// app/api/project/[id]/route.ts import { NextRequest, NextResponse } from "next/server"; import { loadProject } from "@/lib/memory";

export async function GET(_: NextRequest, { params }: { params: { id: string } }) { const files = loadProject(params.id); return NextResponse.json({ files }); }

