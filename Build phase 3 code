// ============================= // 10. UI (app/page.tsx) // ============================= "use client";

import { useState } from "react"; import Preview from "@/components/Preview";

export default function Home() { const [prompt, setPrompt] = useState(""); const [files, setFiles] = useState<Record<string, string>>({}); const [selectedFile, setSelectedFile] = useState<string>(""); const [projectId, setProjectId] = useState<string>(""); const [loading, setLoading] = useState(false);

const generateApp = async () => { setLoading(true); try { const res = await fetch("/api/generate", { method: "POST", headers: { "Content-Type": "application/json" }, body: JSON.stringify({ prompt }), }); const data = await res.json(); setFiles(data.app.files || {}); setProjectId(data.id); const first = Object.keys(data.app.files || {})[0]; setSelectedFile(first); } catch (e) { console.error(e); } finally { setLoading(false); } };

return ( <main className="p-6 max-w-6xl mx-auto"> <h1 className="text-2xl font-bold mb-4">AI App Builder Phase 3</h1>

<textarea
    className="w-full border p-3 rounded mb-4"
    rows={4}
    placeholder="Describe your app..."
    value={prompt}
    onChange={(e) => setPrompt(e.target.value)}
  />

  <button
    onClick={generateApp}
    className="bg-black text-white px-4 py-2 rounded"
    disabled={loading}
  >
    {loading ? "Generating..." : "Generate Full App"}
  </button>

  {projectId && (
    <div className="mt-2 text-sm text-gray-600">Project ID: {projectId}</div>
  )}

  <div className="grid grid-cols-4 gap-4 mt-6">
    <div className="col-span-1 border p-2">
      <h2 className="font-bold">Files</h2>
      {Object.keys(files).map((file) => (
        <div
          key={file}
          className={`cursor-pointer p-1 ${selectedFile === file ? "bg-gray-200" : ""}`}
          onClick={() => setSelectedFile(file)}
        >
          {file}
        </div>
      ))}
    </div>

    <div className="col-span-3">
      {selectedFile && (
        <>
          <h2 className="font-bold mb-2">Preview</h2>
          <Preview code={files[selectedFile]} />

          <pre className="mt-4 bg-gray-900 text-green-400 p-4 rounded overflow-x-auto">
            {files[selectedFile]}
          </pre>
        </>
      )}
    </div>
  </div>
</main>

); }

