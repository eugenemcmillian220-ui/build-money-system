// ============================= // 1. AI ENGINE (lib/openrouter.ts) // ============================= import axios from "axios";

const OR_URL = "https://openrouter.ai/api/v1/chat/completions";

async function callLLM(system: string, user: string) { const res = await axios.post( OR_URL, { model: "openai/gpt-4o-mini", messages: [ { role: "system", content: system }, { role: "user", content: user }, ], temperature: 0.2, }, { headers: { Authorization: Bearer ${process.env.OPENROUTER_API_KEY}, "Content-Type": "application/json", }, timeout: 60_000, } ); return res.data.choices?.[0]?.message?.content ?? ""; }

export async function generateAppSpec(prompt: string): Promise<string> { const system = You are a senior software architect. Produce a STRICT JSON spec for a Next.js app.; const user = Return ONLY JSON with keys: files (object path->code), schema (SQL string), integrations (string[]).\nApp idea: ${prompt}; return callLLM(system, user); }

export async function debugFiles(files: Record<string, string>): Promise<Record<string, string>> { const system = You are a debugging AI. Fix syntax/runtime issues. Keep paths identical. Return ONLY JSON {files:{}}.; const user = Fix these files:\n${JSON.stringify(files)}; const out = await callLLM(system, user); try { const parsed = JSON.parse(out); return parsed.files || files; } catch { return files; // fail-safe } }

