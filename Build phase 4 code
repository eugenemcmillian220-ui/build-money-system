// ============================= // 0. TYPES (lib/types.ts) // ============================= export type GeneratedApp = { files: Record<string, string>; schema?: string; integrations?: string[]; };

// ============================= // 1. AI CORE (lib/llm.ts) // ============================= import axios from "axios"; const OR_URL = "https://openrouter.ai/api/v1/chat/completions";

export async function llm(system: string, user: string) { const res = await axios.post( OR_URL, { model: "openai/gpt-4o-mini", messages: [ { role: "system", content: system }, { role: "user", content: user }, ], temperature: 0.2, }, { headers: { Authorization: Bearer ${process.env.OPENROUTER_API_KEY}, "Content-Type": "application/json", }, timeout: 60_000, } ); return res.data.choices?.[0]?.message?.content ?? ""; }

export async function planSpec(prompt: string) { return llm( "You are a staff engineer. Return STRICT JSON with files, schema, integrations.", ONLY JSON. keys: files(object path->code), schema(string), integrations(string[]). Idea: ${prompt} ); }

export async function debugPass(files: Record<string, string>) { const out = await llm( "You fix build/runtime errors. Keep paths. Return ONLY JSON {files:{}}.", JSON.stringify(files) ); try { return JSON.parse(out).files || files; } catch { return files; } }

// ============================= // 2. SUPABASE (lib/supabase.ts) // ============================= import { createClient } from "@supabase/supabase-js";

export const supabase = createClient( process.env.NEXT_PUBLIC_SUPABASE_URL!, process.env.NEXT_PUBLIC_SUPABASE_ANON_KEY! );

export const supabaseAdmin = createClient( process.env.NEXT_PUBLIC_SUPABASE_URL!, process.env.SUPABASE_SERVICE_ROLE_KEY! );

// SQL table (run once in Supabase SQL editor): // create table projects (id uuid primary key, files jsonb, created_at timestamp default now());

export async function saveProjectDB(id: string, files: Record<string,string>) { await supabaseAdmin.from("projects").upsert({ id, files }); }

export async function loadProjectDB(id: string) { const { data } = await supabaseAdmin.from("projects").select("files").eq("id", id).single(); return data?.files || {}; }

// ============================= // 3. BACKEND + INTEGRATIONS (lib/builders.ts) // ============================= export function attachBackend(files: Record<string,string>, schema?: string) { const out = { ...files }; if (!out["app/api/health/route.ts"]) { out["app/api/health/route.ts"] = import { NextResponse } from 'next/server'; export async function GET(){return NextResponse.json({ok:true});}; } if (!out["lib/db.ts"]) { out["lib/db.ts"] = import { createClient } from '@supabase/supabase-js'; export const db = createClient(process.env.NEXT_PUBLIC_SUPABASE_URL!, process.env.NEXT_PUBLIC_SUPABASE_ANON_KEY!);; } if (schema) out["supabase/schema.sql"] = schema; return out; }

export function applyIntegrations(files: Record<string,string>, integrations?: string[]) { const out = { ...files }; const list = integrations || []; if (list.includes("stripe")) { out["lib/stripe.ts"] = import Stripe from 'stripe'; export const stripe = new Stripe(process.env.STRIPE_SECRET_KEY!, { apiVersion: '2024-06-20' });; out["app/api/checkout/route.ts"] = import { NextResponse } from 'next/server'; export async function POST(){return NextResponse.json({url:'/checkout'});}; } return out; }

// ============================= // 4. GITHUB EXPORT (lib/github.ts) // ============================= import { Octokit } from "@octokit/rest";

export async function exportToGitHub(repoName: string, files: Record<string,string>) { const octokit = new Octokit({ auth: process.env.GITHUB_TOKEN });

const { data: repo } = await octokit.repos.createForAuthenticatedUser({ name: repoName, private: false });

for (const [path, content] of Object.entries(files)) { await octokit.repos.createOrUpdateFileContents({ owner: repo.owner.login, repo: repo.name, path, message: add ${path}, content: Buffer.from(content).toString("base64"), }); }

return repo.html_url; }

// ============================= // 5. VERCEL DEPLOY (lib/vercel.ts) // ============================= import axios from "axios";

export async function deployToVercel(projectName: string, files: Record<string,string>) { const res = await axios.post( "https://api.vercel.com/v13/deployments", { name: projectName, files: Object.entries(files).map(([file, data]) => ({ file, data })), projectSettings: { framework: "nextjs" }, }, { headers: { Authorization: Bearer ${process.env.VERCEL_TOKEN}, }, } );

return res.data.url; }

// ============================= // 6. AGENT LOOP (lib/agent.ts) // ============================= import { v4 as uuidv4 } from "uuid"; import { planSpec, debugPass } from "./llm"; import { attachBackend, applyIntegrations } from "./builders"; import { saveProjectDB } from "./supabase"; import type { GeneratedApp } from "./types";

export async function buildAgent(prompt: string) { // PLAN const raw = await planSpec(prompt); let parsed: GeneratedApp = { files: {} }; try { parsed = JSON.parse(raw); } catch { throw new Error("Invalid JSON"); }

// BUILD let files = attachBackend(parsed.files || {}, parsed.schema); files = applyIntegrations(files, parsed.integrations);

// TEST+FIX LOOP (2 passes) for (let i=0;i<2;i++) { files = await debugPass(files); }

// SAVE const id = uuidv4(); await saveProjectDB(id, files);

return { id, app: { ...parsed, files } }; }

// ============================= // 7. API ROUTES // ============================= // app/api/generate/route.ts import { NextRequest, NextResponse } from "next/server"; import { buildAgent } from "@/lib/agent";

export async function POST(req: NextRequest) { try { const { prompt } = await req.json(); if (!prompt) return NextResponse.json({ error: "Prompt required" }, { status: 400 }); const result = await buildAgent(prompt); return NextResponse.json(result); } catch (e: any) { return NextResponse.json({ error: e.message || "failed" }, { status: 500 }); } }

// app/api/deploy/route.ts import { NextRequest, NextResponse } from "next/server"; import { deployToVercel } from "@/lib/vercel";

export async function POST(req: NextRequest) { const { name, files } = await req.json(); const url = await deployToVercel(name || "ai-app", files); return NextResponse.json({ url }); }

// app/api/github/route.ts import { NextRequest, NextResponse } from "next/server"; import { exportToGitHub } from "@/lib/github";

export async function POST(req: NextRequest) { const { name, files } = await req.json(); const url = await exportToGitHub(name || "ai-app", files); return NextResponse.json({ url }); }

// ============================= // 8. UI (app/page.tsx) // ============================= "use client"; import { useState } from "react"; import Preview from "@/components/Preview";

export default function Home() { const [prompt, setPrompt] = useState(""); const [files, setFiles] = useState<Record<string,string>>({}); const [selectedFile, setSelectedFile] = useState(""); const [deployUrl, setDeployUrl] = useState(""); const [githubUrl, setGithubUrl] = useState(""); const [loading, setLoading] = useState(false);

const generate = async () => { setLoading(true); const res = await fetch("/api/generate", { method: "POST", headers: { "Content-Type": "application/json" }, body: JSON.stringify({ prompt }) }); const data = await res.json(); setFiles(data.app.files); setSelectedFile(Object.keys(data.app.files)[0]); setLoading(false); };

const deploy = async () => { const res = await fetch("/api/deploy", { method: "POST", headers: { "Content-Type": "application/json" }, body: JSON.stringify({ files }) }); const data = await res.json(); setDeployUrl(data.url); };

const pushGitHub = async () => { const res = await fetch("/api/github", { method: "POST", headers: { "Content-Type": "application/json" }, body: JSON.stringify({ files }) }); const data = await res.json(); setGithubUrl(data.url); };

return ( <main className="p-6 max-w-6xl mx-auto"> <h1 className="text-2xl font-bold mb-4">AI App Builder Phase 4</h1>

<textarea className="w-full border p-3 mb-4" value={prompt} onChange={(e)=>setPrompt(e.target.value)} />

  <button onClick={generate} className="bg-black text-white px-4 py-2 mr-2">Generate</button>
  <button onClick={deploy} className="bg-blue-600 text-white px-4 py-2 mr-2">Deploy</button>
  <button onClick={pushGitHub} className="bg-green-600 text-white px-4 py-2">Export GitHub</button>

  {deployUrl && <div className="mt-2">Live: {deployUrl}</div>}
  {githubUrl && <div className="mt-2">Repo: {githubUrl}</div>}

  <div className="grid grid-cols-4 gap-4 mt-6">
    <div>
      {Object.keys(files).map(f => (
        <div key={f} onClick={()=>setSelectedFile(f)} className="cursor-pointer">{f}</div>
      ))}
    </div>
    <div className="col-span-3">
      {selectedFile && <Preview code={files[selectedFile]} />}
    </div>
  </div>
</main>

); }

